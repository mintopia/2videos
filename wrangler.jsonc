{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "2videos",
  "compatibility_date": "2026-06-01",
  // Static-assets-only Worker: no server code, Cloudflare just serves the
  // built SPA. `directory` is the Vite build output. See README "Deploy".
  "assets": {
    "directory": "./dist"
  }
}
